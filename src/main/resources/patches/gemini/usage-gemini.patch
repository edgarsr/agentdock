{
  "pathGlob": "bundle/gemini-*.js",
  "findRegex": "async function main\\(\\)\\s*\\{\\r?\\n\\s*let config;\\r?\\n\\s*const cliStartupHandle = startupProfiler\\.start\\(\"cli_startup\"\\);",
  "replace": "async function outputUsageJson(config) {\n  try {\n    const authType = config.getContentGeneratorConfig?.()?.authType;\n    if (authType !== \"oauth-personal\" && authType !== \"compute-default-credentials\") {\n      return;\n    }\n    const quota = typeof config.refreshUserQuota === \"function\" ? await config.refreshUserQuota() : null;\n    const email = new UserAccountManager().getCachedGoogleAccount();\n    process.stdout.write(\"__GEMINI_USAGE_JSON__\" + JSON.stringify({ email, userTierName: config.getUserTierName?.(), quota }));\n  } catch {\n  }\n  await runExitCleanup();\n  process.exit(0);\n}\nasync function main() {\n  let config;\n  const cliStartupHandle = startupProfiler.start(\"cli_startup\");",
  "alreadyApplied": "__GEMINI_USAGE_JSON__"
}
